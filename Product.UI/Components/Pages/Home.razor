@page "/"
@inject IProductApiClient ApiClient
@inject NotificationService NotificationService
@rendermode InteractiveServer

<PageTitle>Products</PageTitle>

<RadzenText TextStyle="TextStyle.H4" class="rz-mb-4">Products</RadzenText>

@if (_loading)
{
    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
}
else
{
    <RadzenRow Gap="1.5rem">
        <RadzenColumn Size="12" SizeMD="@(_selectedProduct is null ? 12 : 7)">
            <ProductList Products="_products"
                         SelectedProductId="_selectedProduct?.Id"
                         OnProductSelected="OnProductSelected" />
        </RadzenColumn>

        @if (_selectedProduct is not null)
        {
            <RadzenColumn Size="12" SizeMD="5">
                <ProductDetails Product="_selectedProduct"
                                OnPriceUpdated="OnPriceUpdated"
                                OnClose="() => _selectedProduct = null" />
            </RadzenColumn>
        }
    </RadzenRow>
}

@code {
    private List<ProductResponse> _products = [];
    private bool _loading = true;
    private ProductResponse? _selectedProduct;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _products = await ApiClient.GetProductsAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Failed to load products",
                Detail = ex.Message,
                Duration = 6000
            });
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnProductSelected(ProductResponse product)
    {
        _selectedProduct = _selectedProduct?.Id == product.Id ? null : product;
    }

    private void OnPriceUpdated(UpdatePriceResponse result)
    {
        var index = _products.FindIndex(p => p.Id == result.Id);
        if (index >= 0)
            _products[index] = _products[index] with { Price = result.NewPrice, LastUpdated = result.LastUpdated };

        if (_selectedProduct?.Id == result.Id)
            _selectedProduct = _selectedProduct with { Price = result.NewPrice, LastUpdated = result.LastUpdated };
    }
}